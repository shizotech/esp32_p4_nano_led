has_solo_segments = 0;

last_num_outputs = -1;
last_max_leds = -1;

//First ever init
if(!led_segments)
{
	led_segments = [
		[name="Output 1", pin=21, segments=[[name="Segment 1", width=10, height=1, count=1, color="#000000", brightness=255, enabled=1, group="Default"]]]
	];
}

get_color(str)
{
	//LittleFS statt FatFS ?
	if(std.is_json(str))
		return str;
	
	r = 0;
	g = 0;
	b = 0;
	if(str[0] == "#")
	{
		r = std.float(std.hex_to_char(str.substr(1,2))) / 255.0;
		g = std.float(std.hex_to_char(str.substr(3,2))) / 255.0;
		b = std.float(std.hex_to_char(str.substr(5,2))) / 255.0;
	}
	return [r=r,g=g,b=b];
}

interpolate_color(&col1, &col2, trans) {
	return [
		r = math.lerp(col1.r, col2.r, trans),
		g = math.lerp(col1.g, col2.g, trans),
		b = math.lerp(col1.b, col2.b, trans),
	];
}

get_leds_out_count()
{
	max_outs = 0;
	has_solo_segments = 0;
	for(i = 0; i < led_segments.size(); i++)
	{
		it = &led_segments[i];
		
		if(!it.segments)
			continue;
		
		seg_count = 0;
		for(j = 0; j < it.segments.size(); j++)
		{
			seg = &it.segments[j];
			seg_count += seg.width * math.max(1,seg.count);
			if(seg.testout)
				has_solo_segments = 1;
		}
		if(seg_count > max_outs)
			max_outs = seg_count;
	}
	
	return std.int(max_outs);
}

init_driver()
{
	pins = [];
	max_output = get_leds_out_count();
	
	for(i = 0; i < led_segments.size(); i++)
	{
		it = &led_segments[i];
		pins.push_back(it.pin);	
	}
	
	std.print("init driver with pins:");
	std.print(pins);
	std.print("And max led out: " + max_output);
	std.print("LED Channels: " + 3);
	
	if(max_output == 0)
		return;
	if(!pins)
		return;
	
	if(!driver)
	{
		driver = esp32.led_driver(pins, max_output, 3);
		driver.enable_artnet();
		driver.show();
		init_fx();
	}
	else
	{
		driver.blackout();
		driver.show_now();
		driver.init_leds(pins, max_output, 3);
	}
}

last_num_outputs = -1;
last_max_leds = -1;

update_segments()
{
	std.print("get led count...");
	new_max_leds = get_leds_out_count();
	std.print(new_max_leds);
	
	if(last_max_leds != new_max_leds || last_num_outputs != led_segments.size())
	{
		//Re-init driver...
		print("---REINIT DRIVER---");
		init_driver();
	}
	
	if(!driver)
		print("driver was not initialized.");
		return;
	
	last_max_leds = new_max_leds;
	last_num_outputs = led_segments.size();
	
	driver.set_target("SMOOTHBUFFER");
	
	led_segments_groups = 0;
		
	output_id = 0;
	for(i = 0; i < led_segments.size(); i++) {
	
		it = &led_segments[i];
		segment_id = 0;
		current_index = 0;
		
		if(!it.segments)
			continue;
		
		for(j = 0; j < it.segments.size(); j++) {
			seg = &it.segments[j];

			group = &led_segments_groups[seg.group];
			group.push_back(*seg);
			
			ledcount = int(seg.width * math.max(1,seg.height));
			
			//Weird bug:
			//led_segments_groups[seg.group][group_name].push_back() doesnt work as expected ???
			//Debug that !!!
			
			for(k = 0; k < seg.count; k++)
			{			
				//Sort after group and total LED count (to avoid double rendering same segments)
				group_name = string(ledcount);
				entry = &group[group_name];
				//std.print(led_segments_groups);
				entry.push_back([output=output_id, index=current_index, count=ledcount]);
				//std.print(led_segments_groups);
			}
			
			brightness = seg.brightness / 255.0;
			col = get_color(seg.color);
			
			if(has_solo_segments && !seg.testout)
				brightness = 0;
			
			driver.set_pixels(output_id, current_index, seg.width * math.max(1,seg.height) * math.max(1,seg.count), col.r*brightness*255.0, col.g*brightness*255.0, col.b*brightness*255.0);
			current_index += seg.width * math.max(1, seg.height) * math.max(1, seg.count);
			segment_id++;
		}
		
		output_id++;
	}
	
	std.print(led_segments_groups);
	
	driver.set_effect_groups(led_segments_groups);
	
	print("updated segments.");
}

start_effect = None;
current_effect = None;
current_effect_transit = 0.0;

update_anims()
{
	if(!driver)
		std.print("driver was not initialized.");
		return;

	if(!effect_groups)
		return;
	
	for(i = 0; i < effect_groups.size(); i++)
	{
		if(!effect_groups[i].intensity)
			effect_groups[i].intensity = 0.5;
		effect_groups[i].intensity = std.float(effect_groups[i].intensity);
		
		if(!effect_groups[i].speed)
			effect_groups[i].speed = 0.5;
		effect_groups[i].speed = std.float(effect_groups[i].speed);
		
		if(!effect_groups[i].ctrl1)
			effect_groups[i].ctrl1 = 0.5;
		effect_groups[i].ctrl1 = std.float(effect_groups[i].ctrl1);
		
		if(!effect_groups[i].ctrl2)
			effect_groups[i].ctrl2 = 0.5;
		effect_groups[i].ctrl2 = std.float(effect_groups[i].ctrl2);
		
		if(!effect_groups[i].ctrl3)
			effect_groups[i].ctrl3 = 0.5;
		effect_groups[i].ctrl3 = std.float(effect_groups[i].ctrl3);
		
		driver.set_effect(effect_groups.key(i), effect_groups[i].effect);
	}

	if(!current_effect)
		current_effect = effect_groups;
	
	start_effect = current_effect;
	
	current_effect_transit = 0.0;
}

update_anims_thread() {
	for(1) {
		if(current_effect_transit <= 1.0) {
			try {
				
				for(i = 0; i < effect_groups.size(); i++)
				{
					driver.set_effect(effect_groups.key(i), effect_groups[i].effect);
					
					old_col1 = get_color(start_effect[i].color1);
					old_col2 = get_color(start_effect[i].color2);
					
					new_col1 = get_color(effect_groups[i].color1);
					new_col2 = get_color(effect_groups[i].color2);
					
					col1 = interpolate_color(&old_col1, &new_col1, current_effect_transit);
					col2 = interpolate_color(&old_col2, &new_col2, current_effect_transit);

					current_effect[i].color1 = col1;
					current_effect[i].color2 = col2;

					driver.set_effect_color1(effect_groups.key(i), col1.r, col1.b, col1.g);
					driver.set_effect_color2(effect_groups.key(i), col2.r, col2.b, col2.g);
					
					//driver.set_effect_color1(effect_groups.key(i), new_col1.r, new_col1.b, new_col1.g);
					//driver.set_effect_color2(effect_groups.key(i), new_col2.r, new_col2.b, new_col2.g);
					
					
					//std.print(col1);
					
					current_effect[i].intensity = math.lerp(start_effect[i].intensity, effect_groups[i].intensity, current_effect_transit);
					current_effect[i].speed = math.lerp(start_effect[i].speed, effect_groups[i].speed, current_effect_transit);
					current_effect[i].ctrl1 = math.lerp(start_effect[i].ctrl1, effect_groups[i].ctrl1, current_effect_transit);
					current_effect[i].ctrl2 = math.lerp(start_effect[i].ctrl2, effect_groups[i].ctrl2, current_effect_transit);
					current_effect[i].ctrl3 = math.lerp(start_effect[i].ctrl3, effect_groups[i].ctrl3, current_effect_transit);
								
					//std.print(current_effect[i].intensity);			
							
					driver.set_effect_intensity(effect_groups.key(i), current_effect[i].intensity);
					driver.set_effect_speed(effect_groups.key(i), current_effect[i].speed);
					driver.set_effect_ctrl1(effect_groups.key(i), current_effect[i].ctrl1);	
					driver.set_effect_ctrl2(effect_groups.key(i), current_effect[i].ctrl2);	
					driver.set_effect_ctrl3(effect_groups.key(i), current_effect[i].ctrl3);		
					
					/*
					driver.set_effect_intensity(effect_groups.key(i), effect_groups[i].intensity);
					driver.set_effect_speed(effect_groups.key(i), effect_groups[i].speed);
					driver.set_effect_ctrl1(effect_groups.key(i), effect_groups[i].ctrl1);	
					driver.set_effect_ctrl2(effect_groups.key(i), effect_groups[i].ctrl2);	
					driver.set_effect_ctrl3(effect_groups.key(i), effect_groups[i].ctrl3);
					*/
				}
			}
			catch(e) {}
			
			current_effect_transit += 0.01;
			std.sleep(16);
			continue;
		}
		
		std.sleep(100);
	}
}

