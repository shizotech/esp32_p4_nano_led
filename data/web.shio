class web_page
{
  html = "";

  __init__() {
    html += render_templ("page_start", [styles=templates["styles"]]);
  }

  get()
  {
    final_html = html;
    if(!closed_last_section)
			final_html += render_templ("section_end");
    final_html += render_templ("page_end");
    return final_html;
  }

  add_section(title, infotext = "")
	{
		if(!closed_last_section)
			html += render_templ("section_end");
		closed_last_section = 1;
		if(!title.empty())
			html += render_templ("section_start", [section_title = title, section_text=infotext]);
			closed_last_section = 0;
	}

  add_ctrl(type, name, cb, options)
  {
    id = get_id(name);
    
    options.id = id;
    options.name = name;
    
    str = render_templ("control_" + type, options);	
    
    server.post("/"+id, [this, cb](post_data)
    {
      cb(post_data);
      return "success";
    });
    
    html += str;
  }

  add_slider(name, cb, minv, maxv, defaultv)
  {
    options = [min=minv, max=maxv, value=defaultv];
    
    id = get_id(name);
    
    if(esp32.config().has(id))
      options.value = esp32.config()[id];
    
    cb2 = [id](post_data)
    {
      std.print("updating: " + id);
      esp32.config()[id] = post_data.value;
      trigger_config_update = 1;
    };
    
    if(std.is_function(cb))
      cb2 = cb;
    
    add_ctrl("slider", name, cb2, options);
  }

  add_text(name, cb, defaultv)
  {
    options = [value=defaultv];
    
    id = get_id(name);
    
    if(esp32.config().has(id))
      options.value = esp32.config()[id];
    
    cb2 = [id](post_data)
    {
      std.print("updating: " + id);
      esp32.config()[id] = post_data.value;
      trigger_config_update = 1;
    };
    
    if(std.is_function(cb))
      cb2 = cb;
    
    add_ctrl("text", name, cb2, options);
  }

  add_checkbox(name, cb, defaultv)
  {
    options = [checked=defaultv];
    
    id = get_id(name);
    
    if(esp32.config().has(id))
      options.checked = esp32.config()[id];
    
    cb2 = [id](post_data)
    {
      std.print("updating: " + id);
      esp32.config()[id] = post_data.value;
      trigger_config_update = 1;
    };
    
    if(std.is_function(cb))
      cb2 = cb;

    //'checked' html attribute
		if(options.checked)
			options.checked = "checked";
		else
			options.checked = "";
    
    add_ctrl("checkbox", name, cb2, options);
  }

  add_template(alias, args = None) {
	  html += render_templ(alias, &args);
  }

  get_id(name)
  {
    id = name.lowercase();
    id = id.removecharsexcept("abcdefghijklmnopqrstuvwqyz0123456789");
    return id;
  }

  render(src, args = None) {
    if(!args)
      return src;
    for(i = 0; i < args.size(); i++) {
      src = src.replace("{{"+args.key(i)+"}}", args[i]);
    }
    return src;
  }

  render_templ(alias, args = 0)
  {
	if(!templates.has(alias))
		std.print("Cannot find: ", alias);
		return "";
	  
    return render(&templates[alias], &args);
  }

  closed_last_section = 1;
}

class web_menu
{
  header_buttons = [
	"EFFECTS" = "/home",
    "SETTINGS" = "/settings",
	"LED SETUP" = "/segments",
	"DMX" = "/dmx",
    "FILES" = "/filebrowser",
    "UPDATE" = "/update"
  ];

  __init__() {
    on("/", [this]()
    {
      hdr = "";
      //<a href="/home" target="contentFrame">🏠 Home</a>
      for(i = 0; i < this.header_buttons.size(); i++)
      {
        hdr += "<a href='" + this.header_buttons[i] + "' target='contentFrame'>" + this.header_buttons.key(i) + "</a>\n";
      }

      name = net.name();
      name += " [" + net.mac() + "] (" + net.ip() + ")";
      return this.render_templ("main", [name = name, header_buttons = hdr]);
    });
	
	on("/home", [this]()
	{
		page = web_page();
		page.add_template("animation_editor");
		return page.get();
	});

    on("/settings", [this]()
    {
		page = web_page();
		page.add_section("Network", "Network settings");
		page.add_text("Name", 0, "ESP32");
		page.add_text("Password", 0, "admin");
		page.add_text("IP", 0, "2.0.0.10");
		page.add_text("Gateway", 0, "2.0.0.1");
		page.add_text("Netmask", 0, "255.255.255.0");
		page.add_checkbox("DHCP Server", 0, 0);

		page.add_section("Connect to WLANs");

		wlans = esp32.config("wlans");
		
		if(!wlans)
			wlans = [];

		wlans.resize(6);

		add_wlan_option = [page, &wlans](numid)
		{
			def_ssid = wlans[numid].ssid;
			if(!def_ssid)
				def_ssid = "";
			def_pw = wlans[numid].password;
			if(!def_pw)
				def_pw = "";
			
			page.add_text("WLAN " + (numid+1) + " Name", [numid](post_data)
			{
				print("updating: wlan" + numid);
				wlans = esp32.config("wlans");
				
				if(!wlans)
					wlans = [];		
				if(numid >= wlans.size())
					wlans.resize(numid+1);
				
				wlans[numid].ssid = post_data.value;
				esp32.set_config("wlans", wlans);
				trigger_config_update = 1;
			}, def_ssid);
			
			page.add_text("WLAN " + (numid+1) + " Password", [numid](post_data)
			{
				print("updating: wlan" + numid);
				wlans = esp32.config("wlans");
				
				if(!wlans)
					wlans = [];		
				if(numid >= wlans.size())
					wlans.resize(numid+1);
				
				wlans[numid].password = post_data.value;
				esp32.set_config("wlans", wlans);
				trigger_config_update = 1;
			}, def_pw);
		};
		

		for(i = 0; i < wlans.size(); i++)
		{
			add_wlan_option(i);
		}
	  
		return page.get();
    });
	
	on("/segments", [this]()
	{
		page = web_page();
		page.add_template("segment_editor");
		return page.get();
	});
	
	on_json("/segments_get", [this](post_data)
	{	
		return led_segments;
	});
	
	on_post("/segments_update", [this](post_data)
	{	
		print("update segments...");
		segments_json = std.json(post_data.plain);
		if(!segments_json)
			return;
		//std.print(post_data.plain);
		led_segments = segments_json;
		update_segments();
		trigger_segment_update = true;
		return post_data.plain;
	});
	
	on_json("/effects_get", [this](post_data)
	{	
		return [effects=driver.get_effects(),
				palettes = [
					[name="Warm",id="builtin_warm"],
					[name="Cool",id="builtin_cool"],
					[name="Party",id="builtin_party"],
				],
				settings = effect_groups,
			];
	});
	
	on_post("/animations_update", [this](post_data)
	{	
		std.print("Animation update...");
		effect_groups = std.json(post_data.plain);
		if(!effect_groups)
			return "";
		update_anims();
		trigger_effect_update = true;
		std.print("OK");
		return "";
	});
  }

  on(url, cb) {
    server.on(url, [cb]()
    {
		try {
			return cb();
		}
		catch(e) {
			return "";
		}
    });
  }

	on_json(url, cb)
	{
		server.post_json(url, [this, cb](post_data)
		{
			try {
				return cb(post_data);
			}
			catch(e) {
				return "";
			}
		});
	}

	on_post(url, cb)
	{
		server.post(url, [this, cb](post_data)
		{
			try {
				return cb(post_data);
			}
			catch(e) {
				return "";
			}
		});
	}

	render(src, args) {
		if(!args)
			return src;
		for(i = 0; i < args.size(); i++) {
			src = src.replace("{{"+args.key(i)+"}}", args[i]);
		}
		return src;
	}

	render_templ(alias, args)
	{
		try {
			return render(&esp32.web_template(alias), &args);
		}
		catch(e) {
			return "";
		}
	}
}

menu = web_menu();

update_config_thread()
{
	for(1)
	{
		//This is to relax saving on update spam...
		if(trigger_config_update)
		{
			trigger_config_update = 0;
			sleep(500);
			fileio.write_string("/config.json", esp32.config());
			print(esp32.config());
		}
		if(trigger_segment_update) {
			trigger_segment_update = 0;
			fileio.write_json("segments.json", led_segments);
		}
		if(trigger_effect_update) {
			trigger_effect_update = 0;
			fileio.write_json("effects.json", effect_groups);
		}
		
		sleep(100);
	}
}

init_driver();
update_segments();
update_anims();
init_driver();

anim_thread = std.thread(update_anims_thread);
anim_thread.run();

config_thread = std.thread(update_config_thread);
config_thread.run();

